# ===== Supabase (o worker usa a SERVICE ROLE — é secreta, nunca vai pro app) =====
SUPABASE_URL=https://aifadvyxsefxfcgzgqol.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_aqui_a_service_role_key

# ===== Cloudflare R2 =====
R2_ACCOUNT_ID=seu_account_id_do_cloudflare
R2_ACCESS_KEY_ID=sua_access_key_id_do_r2
R2_SECRET_ACCESS_KEY=sua_secret_access_key_do_r2
R2_BUCKET=porter-music
# Opcional: URL pública do bucket (se você ligar o acesso público / r2.dev).
# Se preencher, salvamos a URL tocável em tracks.metadata.public_url
R2_PUBLIC_BASE_URL=

# ===== Limites e qualidade (já vêm com o combinado; mude só se quiser) =====
MAX_TRACKS=170
MAX_TRACK_DURATION_SECONDS=960
MAX_FILE_MB=15
AUDIO_BITRATE=128
POLL_SECONDS=10
# Heartbeat continua sendo enviado mesmo durante downloads longos.
WORKER_HEARTBEAT_SECONDS=30
# Teste leve de acesso ao bucket R2 a cada 5 minutos.
R2_HEALTHCHECK_SECONDS=300
# A fila de exclusao e consultada separadamente do polling de downloads.
STORAGE_DELETION_POLL_SECONDS=30
# A auditoria completa dos objetos roda em background, uma vez ao dia.
STORAGE_AUDIT_INTERVAL_SECONDS=86400
STORAGE_AUDIT_START_DELAY_SECONDS=60
MAX_ATTEMPTS=3
# Limite global entre réplicas do Worker (aplicado atomicamente no Supabase).
MAX_CONCURRENT_JOBS=1
# Pequeno pool por playlist para evitar bloqueios e rate limits.
TRACK_CONCURRENCY=2
# O código limita este valor a no máximo 2 tentativas por faixa.
TRACK_MAX_ATTEMPTS=2
# Job sem atualização por 30 min é considerado abandonado e volta para a fila.
STALE_JOB_SECONDS=1800
STALE_JOB_CHECK_SECONDS=60
# Mantido para compatibilidade com instalações anteriores.
GLOBAL_FAILURE_ABORT_THRESHOLD=3
# Bloqueio global do YouTube pausa a fila por 15 min sem gastar tentativas.
YOUTUBE_CIRCUIT_OPEN_SECONDS=900
# Nenhuma tentativa de uma faixa pode congelar o job para sempre.
DOWNLOAD_ATTEMPT_TIMEOUT_SECONDS=120
YTDLP_NETWORK_TIMEOUT_SECONDS=30
# Tempo máximo da solicitação inteira, incluindo resolução e todas as faixas.
REQUEST_TIMEOUT_SECONDS=3600
# Tempo total para o spotDL ler Spotify e localizar as faixas no YouTube.
# Nenhum áudio é baixado do Spotify.
SPOTDL_RESOLVE_TIMEOUT_SECONDS=600
# Opcional: delega a resolução Spotify -> YouTube a um serviço interno.
# Vazio = este worker Docker usa spotDL localmente, sem baixar áudio do Spotify.
SPOTIFY_RESOLVER_URL=
# Obrigatório quando SPOTIFY_RESOLVER_URL estiver preenchida; nunca usar no App.
SPOTIFY_RESOLVER_TOKEN=
# Emergencial para redes privadas explicitamente confiáveis. O padrão bloqueia
# loopback, link-local e IPs privados para reduzir SSRF.
SPOTIFY_RESOLVER_ALLOW_PRIVATE=false

# ===== YouTube (IMPORTANTE p/ o download funcionar no Railway) =====
# Fallback apenas para conteúdo que realmente exige login. Links públicos usam
# o provedor automático de PO Token configurado abaixo, evitando troca frequente.
YOUTUBE_COOKIES=
# Alternativa: caminho de um arquivo de cookies já presente no container.
YOUTUBE_COOKIES_FILE=
# Ordem dos player clients tentados no download (cascata). "default" = deixa o
# yt-dlp extrair sozinho (mais robusto p/ "Requested format is not available").
YT_PLAYER_CLIENTS=mweb,web_safari,default
# Substituição automática: se uma faixa for indisponível (geo/removida/sem áudio),
# busca outra versão da mesma música e importa no lugar. Deixe ligado.
ENABLE_AUTO_SUBSTITUTE=true
SUBSTITUTE_SEARCH_LIMIT=4
# PO Token automático para links públicos. No Railway, use a imagem versionada
# brainicism/bgutil-ytdlp-pot-provider:1.3.1 na porta 4416 e a URL privada.
POT_PROVIDER_BASE_URL=
